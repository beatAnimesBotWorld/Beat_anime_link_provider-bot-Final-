# ══════════════════════════════════════════
#         MANDATORY - BOT WILL NOT START
# ══════════════════════════════════════════

# Your bot token from @BotFather
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# Your PostgreSQL database URL
DATABASE_URL=postgresql://username:password@host:5432/dbname

# Your Telegram user ID (get it from @userinfobot)
ADMIN_ID=829342319

# ══════════════════════════════════════════
#         WELCOME MESSAGE SETTINGS
# ══════════════════════════════════════════

# Channel ID to copy welcome message from (must be negative)
WELCOME_SOURCE_CHANNEL=-1002530952988

# Message ID inside that channel to copy as welcome
WELCOME_SOURCE_MESSAGE_ID=32

# Your public anime channel link
PUBLIC_ANIME_CHANNEL_URL=https://t.me/BeatAnime

# Your request channel link
REQUEST_CHANNEL_URL=https://t.me/Beat_Hindi_Dubbed

# Your admin username (without @)
ADMIN_CONTACT_USERNAME=Beat_Anime_Ocean

# ══════════════════════════════════════════
#         PANEL IMAGE URLs (OPTIONAL)
# ══════════════════════════════════════════

# Image shown in /help command
HELP_IMAGE_URL=https://i.imgur.com/yourimage.jpg

# Image shown in /settings panel
SETTINGS_IMAGE_URL=https://i.imgur.com/yourimage.jpg

# Image shown in /stats panel
STATS_IMAGE_URL=https://i.imgur.com/yourimage.jpg

# Image shown in admin panel
ADMIN_PANEL_IMAGE_URL=https://i.imgur.com/yourimage.jpg

# ══════════════════════════════════════════
#         TRANSITION STICKER (OPTIONAL)
# ══════════════════════════════════════════

# Sticker file_id OR animated GIF URL shown on /start
# Leave empty to disable
TRANSITION_STICKER=

# ══════════════════════════════════════════
#         TMDB API (OPTIONAL)
# ══════════════════════════════════════════

# Get your free key from https://www.themoviedb.org/settings/api
# Required only if you use /movie or /tvshow commands
TMDB_API_KEY=your_tmdb_api_key_here

# ══════════════════════════════════════════
#         BROADCAST SETTINGS
# ══════════════════════════════════════════

# Users per broadcast chunk (default: 1000)
BROADCAST_CHUNK_SIZE=1000

# Minimum users before throttled broadcast kicks in (default: 5000)
BROADCAST_MIN_USERS=5000

# Minutes between each broadcast chunk (default: 20)
BROADCAST_INTERVAL_MIN=20

# ══════════════════════════════════════════
#         LINK SETTINGS
# ══════════════════════════════════════════

# Minutes before generated invite links expire (default: 5)
LINK_EXPIRY_MINUTES=5

# ══════════════════════════════════════════
#         RENDER / SERVER SETTINGS
# ══════════════════════════════════════════

# Port for health check server (default: 8080)
PORT=8080

# Auto-set by Render, leave empty locally
RENDER_EXTERNAL_URL=
